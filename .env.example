# Copy this file to .env and fill in your values.
# Never commit .env — it is gitignored.

# Robinhood credentials (required for `positions` and `advise` commands)
# robin_stocks caches the OAuth token after first login (~/.tokens/robinhood.pickle)
RH_USERNAME=your_robinhood_email@example.com
RH_PASSWORD=your_robinhood_password

# Optional but strongly recommended: TOTP secret from authenticator-app MFA.
# In Robinhood: Settings → Security → Two-Factor Authentication → Authenticator App —
# copy the setup key shown during enrollment. With this set (plus `pip install pyotp`),
# login passes a 6-digit code directly and skips the flaky device-approval flow.
# RH_MFA_SECRET=your_totp_setup_key

# FRED API key — used for macroeconomic data (yield curve, risk-free rate)
# Free at https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key

# Finnhub API key — used for insider transactions, news sentiment, earnings, ETF holdings
# Free at https://finnhub.io (60 calls/min on free tier — sufficient for all commands)
FINNHUB_API_KEY=your_finnhub_api_key

# Discord webhook URL — optional, used by weekly_sync.py for portfolio reports
# Create one in your Discord server under Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN
